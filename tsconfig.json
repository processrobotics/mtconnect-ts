{
  "compilerOptions": {
    "target": "es2019",
    "module": "ESNext",
	"moduleResolution": "node",
    "rootDir": "src",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
	"allowJs": true,
	"lib": ["es2018", "es2019", "dom"],
	"jsx": "react-jsx",
	"skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "demo/**"]
}